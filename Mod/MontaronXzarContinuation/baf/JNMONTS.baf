END

IF
	GlobalGT("Chapter","GLOBAL",%bg2_chapter_1%)
	InParty(Myself)
	RealGlobalTimerExpired("JNMONTMaeVarTalkTimer","GLOBAL")
	See(Player1)
	!StateCheck(Player1,CD_STATE_NOTVALID)
	!StateCheck(Myself,CD_STATE_NOTVALID)
	!See([ENEMY])
	CombatCounter(0)
	Global("JNMONTMaeVarTalk","GLOBAL",1)
THEN
