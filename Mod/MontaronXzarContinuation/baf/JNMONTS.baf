/*
JNMONTBg1 = 1 means Montaron traveled with the player in BG1
JNMONTBg1 = 0 means he didn't

JNMONTRedemption can be increased and at a certain point allows for a different ending for Montaron
Current Max = 0

JNMONTResurrected == 1 set in Priest Dialogue, use maybe for ToB?

JNMONTSpawnedInSoa == 2 -> Montaron was spawned and talked to in SoA
instead of NumTimesTalkedTo(0), because EET compat
*/

IF
	GlobalGT("Chapter","GLOBAL",%bg2_chapter_1%)
    See([PC])
	Global("JNMONTSpawnedInSoa","GLOBAL",0)
	GlobalLT("JNMONTSummoned","GLOBAL",1)
THEN
    RESPONSE #100
		DestroyAllEquipment()
		Wait(2)
		FaceObject(Player1)
		Wait(2)
		SetGlobal("JNMONTSpawnedInSoa","GLOBAL",1)
        Dialogue([PC])
END

/* Script to set XP */

IF
	GlobalGT("Chapter","GLOBAL",%bg2_chapter_1%)
	InParty(Myself)
	Global("JNMONTExperienceSet","GLOBAL",0)
	XPLT(Player1,160000)
THEN
	RESPONSE #100
		SetGlobal("JNMONTExperienceSet","GLOBAL",1)
		Continue()
END

IF
	GlobalGT("Chapter","GLOBAL",%bg2_chapter_1%)
	InParty(Myself)
	Global("JNMONTExperienceSet","GLOBAL",0)
	XPGT(Player1,159999)
	XPLT(Player1,250000)
THEN
	RESPONSE #100
		SetGlobal("JNMONTExperienceSet","GLOBAL",1)
		ChangeStat(Myself,XP,160000,SET)
		Continue()
END

