	~%MOD_FOLDER%/dlg/JNMONT25.d~
	~%MOD_FOLDER%/dlg/JNMON25J.d~
	~%MOD_FOLDER%/dlg/JNMON25P.d~
	
	~%MOD_FOLDER%/baf/JNMON25S.baf~

// Patch Montaron's bg1 creatures to have my scripts
ACTION_IF GAME_IS ~eet~ BEGIN

ACTION_FOR_EACH creature IN montar montar2 montar4 montar6 BEGIN
	ACTION_IF FILE_EXISTS_IN_GAME ~%creature%.cre~ THEN BEGIN
		COPY_EXISTING ~%creature%.cre~ ~override~
			SAY SELECT_RARE1 @31 /* Good or bad, you'll go the way of all flesh. */
			SAY SELECT_RARE2 @32 /* 'Tis a wonder you've lived as long as ye have. */
			SAY CRITICAL_HIT @33 /* The smell of flesh! */
			SAY CRITICAL_MISS @34 /* some moan */
			SAY TARGET_IMMUNE @35 /* Yer wit be as sharp as my blade. */
			SAY PICKED_POCKET @36 /* My equal is a talent of many men. */
			SAY SET_A_TRAP @37 /* All of them fools! */
			SAY HIDDEN_IN_SHADOWS @38 /* Do not make light of me. */
			SAY SPELL_DISRUPTED @39 /* Soo stupid! */

	END
END

END

// Add Montaron's dialogues and scripts to the game
APPEND ~pdialog.2da~
~%jnmontdv% JNMONTP JNMONTJ JNMONTD JNMON25P JNMON25J JNMON25D JNMON25S~
UNLESS ~%jnmontdv%~

// Banter
APPEND ~interdia.2da~
~%jnmontdv% JNBMONT JNBMON25~
UNLESS ~%jnmontdv%~

// Other creatures & scripts, not related to Montaron's creature

COPY ~%MOD_FOLDER%/cre/JNVESP.cre~ ~override/JNVESP.cre~
	SAY NAME1 @50 /* Vesper */
	SAY NAME2 @50 /* Vesper */
	SAY INITIAL_MEETING @51 /* Oh, my life is in shambles. */
	SAY SELECT_COMMON1 @51 /* Oh, my life is in shambles. */
	SAY DYING ~~ [JNLOT04]

	WRITE_ASCII 0x248 ~JNVESPS~ #8
	WRITE_ASCII 0x2cc ~JNVESP~ #8
	WRITE_ASCII 0x280 ~JNVESP~  #32
	WRITE_ASCII 0x34  ~JNVESPM~ #8  // medium portrait
	WRITE_ASCII 0x3c  ~JNVESPL~ #8  // large portrait

COPY ~%MOD_FOLDER%/cre/JNDAVR.cre~ ~override/JNDAVR.cre~
	SAY NAME1 @60 /* Davron */
	SAY NAME2 @60 /* Davron */

	// Give my custom cloak to Davron
	WRITE_ASCII 0x8a8 ~JNCLK01~ #8
	WRITE_ASCII 0x65e ~7~ #2
	
	WRITE_ASCII 0x248 ~JNDAVRS~ #8
	WRITE_ASCII 0x2cc ~JNDAVR~ #8
	WRITE_ASCII 0x280 ~JNDAVR~ #32
	WRITE_ASCII 0x34  ~JNDAVRM~ #8  // medium portrait
	WRITE_ASCII 0x3c  ~JNDAVRL~ #8  // large portrait

// Zhentarim Mage
COPY_EXISTING ~MAGE20.CRE~ ~override/JNGMAGE.CRE~
	SAY NAME1 @61 /* Zhentarim Mage */
	SAY NAME2 @61 /* Zhentarim Mage */
	
	WRITE_ASCII 0x280 ~JNGMAGE~ #32

ADD_JOURNAL @1000002 @1000003 @1000004 USING ~%MOD_FOLDER%/tra/%LANGUAGE%/SETUP.tra~

COPY ~%MOD_FOLDER%/itm/JNDAG01.itm~ ~override/JNDAG01.itm~
	SAY NAME1 @200
	SAY NAME2 @200
	SAY UNIDENTIFIED_DESC @201
	SAY DESC @202

	WRITE_ASCII 0x11e ~%jnmontdv%~ #8 // variable for equip restriction
	
COPY ~%MOD_FOLDER%/itm/JNSCRL1.itm~ ~override/JNSCRL1.itm~
	SAY NAME1 @210
	SAY NAME2 @210
	SAY DESC @211
	
COPY ~%MOD_FOLDER%/itm/JNCLK01.itm~ ~override/JNCLK01.itm~
	SAY NAME1 @220
	SAY NAME2 @221
	SAY UNIDENTIFIED_DESC @222
	SAY DESC @223

// Modify Docks Area to spawn Montarons Corpse and prevent his standard spawning script

EXTEND_TOP ~AR0309.bcs~ ~%MOD_FOLDER%/baf/AR0309.baf~

COPY_EXISTING "AR0300.ARE" override
LPF fj_are_structure
    INT_VAR
    fj_type        = 11 // Barrel
    fj_loc_x       = 1561
    fj_loc_y       = 3557
    fj_box_left    = 1561
    fj_box_top     = 3494
    fj_box_right   = 1591
    fj_box_bottom  = 3542
    fj_vertex_0    = 1562 + (3529 << 16)
    fj_vertex_1    = 1568 + (3540 << 16)
    fj_vertex_2    = 1573 + (3543 << 16)
    fj_vertex_3    = 1581 + (3542 << 16)
	fj_vertex_4    = 1588 + (3535 << 16)
	fj_vertex_5    = 1591 + (3526 << 16)
	fj_vertex_6    = 1590 + (3501 << 16)
	fj_vertex_7    = 1586 + (3497 << 16)
	fj_vertex_8    = 1578 + (3493 << 16)
	fj_vertex_9    = 1569 + (3493 << 16)
	fj_vertex_10	  = 1561 + (3499 << 16)
	fj_vertex_11   = 1561 + (3525 << 16)
    STR_VAR
    fj_structure_type = container
    fj_name           = ~JNBarrel~
	fj_trap_script = ~JNMBODY~
END

// Epilogue
EXTEND_TOP ~AR6200.bcs~ ~%MOD_FOLDER%/baf/AR6200.baf~

COPY ~%MOD_FOLDER%/epilogue/JNMONZZ.2da~ ~override/JNMON01.2da~
REPLACE ~99999~ @500

COPY ~%MOD_FOLDER%/epilogue/JNMONZZ.2da~ ~override/JNMON02.2da~
REPLACE ~99999~ @501

// EET related code
ACTION_IF GAME_IS ~eet~ BEGIN // check if EET
	// COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/dlg/eet/FATESP.d~
INCLUDE ~EET/other/EET_functions.tph~
LAF ~EET_NPC_TRANSITION~
  INT_VAR
    type = 3
    default_ToB = 0 //controls if NPC should be spawnable in ToB when the game has been started in ToB (no by default - 0)
    clean_ToB = 1 //cleans out existing EET code in FATESP.DLG, AR4000.BCS, AR4500.BCS for DV specified in clean_ToB_DV
  STR_VAR
    dv = "%jnmontdv%" //Death Variable (script name) of the NPC (must be the same in BG1/SoD/BG2/ToB)
    override_BG1 = "MONTARON" //name of the override NPC script in BG1
    override_SoD = "JNMON9S" //name of the override NPC script in SoD (use BG1 one if doesn't exist)
    override_SoA = "JNMONTS" //name of the override NPC script in SoA
    override_ToB = "JNMON25S" //name of the override NPC script in ToB (use SoA one if doesn't exist)
    dialog_ToB = "JNMONT25" //name of the dialogue file used after spawning NPC in ToB (use SoA POST dialogue or initial SoA dialogue file if doesn't exist)
    cre_ToB = "JNMON25" //if type = 4 and/or default_ToB = 1 name of the ToB CRE file is needed (used to create new CRE rather than migrating existing one from SoA)
    traFile = "" //an optional TRA file that will be used for the TRA references defined in "string"
    string = "@600" //FATESP summon text (example: "Bring me Quayle, the gnome cleric/illusionist.") or TRA string number
    stringPosDV = "Nalia" //set the DV of NPC right below your response (used for sorting FATESP responses alphabetically)
      //Aerie, Ajantis, Alora, Anomen, Baeloth, Branwen, Cernd, Coran, Corwin, Dorn, Dynaheir, Edwin, Eldoth, Faldorn, Garrick,
      //Glint, HaerDalis, Hexxat, Imoen2, Jaheira, Jan, Kagain, Keldorn, Khalid, Kivan, Korgan, MKhiin, Mazzy, Minsc, Montaron,
      //Nalia, Neera, Quayle, Rasaad, Safana, SharTeel, Skie, Tiax, Valygar, Viconia, Voghiln, Wilson, Xan, Xzar, Yeslick, Yoshimo
      //variable not set (default) = NPC name appended at the end of summoning list
    SummonedVar = "JNMONTSummoned" //set it only if you want to use different var name than %dv%Summoned (useless in most cases)
    SpawnPlaneVar = "" //set it only if you want use different var name than %dv%SpawnPlane (useless in most cases)
    clean_ToB_DV = "Montaron" //if clean_ToB = 1 existing code for this DV will be removed from FATESP.DLG, AR4000.BCS, AR4500.BCS
END
END ELSE BEGIN // different Fate Spirit dialogue patching for BG2EE
	COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/dlg/FATESP.d~
END

BEGIN @3000 DESIGNATED 3000 /* Realistic sharper portrait for Xzar and Montaron (by NolSol on NexusMods) */
REQUIRE_PREDICATE GAME_IS ~bgee bg2ee eet~ @3001

COPY ~%MOD_FOLDER%/bmp/MONTARM.bmp~ ~override/MONTARM.bmp~
COPY ~%MOD_FOLDER%/bmp/MONTARL.bmp~ ~override/MONTARL.bmp~

ACTION_IF GAME_IS ~bgee eet~ BEGIN
	COPY ~%MOD_FOLDER%/bmp/XZARM.bmp~ ~override/XZARM.bmp~
	COPY ~%MOD_FOLDER%/bmp/XZARL.bmp~ ~override/XZARL.bmp~
END

BEGIN @4000 DESIGNATED 4000 /* Portraits for new NPCs (besides Montaron) */
REQUIRE_PREDICATE GAME_IS ~bg2ee eet~ @4001
REQUIRE_COMPONENT ~Setup-MontaronXzarContinuation.tp2~ ~2000~ @2102

COPY ~%MOD_FOLDER%/bmp/JNVESPM.bmp~ ~override/JNVESPM.bmp~
COPY ~%MOD_FOLDER%/bmp/JNVESPL.bmp~ ~override/JNVESPL.bmp~
COPY ~%MOD_FOLDER%/bmp/JNDAVRM.bmp~ ~override/JNDAVRM.bmp~
COPY ~%MOD_FOLDER%/bmp/JNDAVRL.bmp~ ~override/JNDAVRL.bmp~

