BACKUP ~weidu_external/backup/MontaronXzarContinuation~
AUTHOR ~jnweeBg (janwburner@gmail.com)~
VERSION ~v1.0~
AUTO_EVAL_STRINGS
AUTO_TRA ~%MOD_FOLDER%/tra/%s~
README ~%MOD_FOLDER%/README.html~

// EET Chapter handling
ALWAYS
  ACTION_IF NOT VARIABLE_IS_SET bg2_chapter BEGIN
    ACTION_IF GAME_IS ~eet~ BEGIN
      OUTER_SET bg2_chapter = 12 // EET uses continuous chapter numbering from BG1 through TOB and this starts at "12" in BGII
    END ELSE BEGIN
      OUTER_SET bg2_chapter = 0 // all other game types (BGII(:EE), BGT) restart chapter numbering in SOA
    END
    OUTER_FOR (i=1; i<=10; i=i+1) BEGIN
      OUTER_SET bg2_chapter = bg2_chapter + 1
      OUTER_SPRINT name_source ~bg2_chapter_%i%~
      OUTER_SET EVAL ~%name_source%~ = bg2_chapter
    END
  END
END

LANGUAGE 
    ~english~
    ~english~
    ~%MOD_FOLDER%/tra/english/SETUP.tra~
	
BEGIN @1000 DESIGNATED 1000
REQUIRE_PREDICATE (GAME_IS ~bgee eet~ AND FILE_EXISTS_IN_GAME ~bd0103.are~) @1001
FORBID_COMPONENT ~EET_end.tp2~ ~0~ @2002
FORBID_COMPONENT ~EET_end.tp2~ ~1~ @2002

// check for mod merger
ACTION_IF ((FILE_EXISTS ~dlc/sod-dlc.zip~) OR (FILE_EXISTS ~sod-dlc.zip~)) THEN BEGIN
	FAIL @1002
END

// Copy new sounds over
COPY ~%MOD_FOLDER%/tra/%LANGUAGE%/sound~ ~override~

// Add a couple new sounds to Montaron
ACTION_FOR_EACH creature IN montar montar2 montar4 montar6 BEGIN
	ACTION_IF FILE_EXISTS_IN_GAME ~%creature%.cre~ THEN BEGIN
		COPY_EXISTING ~%creature%.cre~ ~override~
			SAY SELECT_RARE1 @31 /* Good or bad, you'll go the way of all flesh. */
			SAY SELECT_RARE2 @32 /* 'Tis a wonder you've lived as long as ye have. */
			SAY CRITICAL_HIT @33 /* The smell of flesh! */
			SAY CRITICAL_MISS @34 /* some moan */
			SAY TARGET_IMMUNE @35 /* Yer wit be as sharp as my blade. */
			SAY PICKED_POCKET @36 /* My equal is a talent of many men. */
			SAY SET_A_TRAP @37 /* All of them fools! */
			SAY HIDDEN_IN_SHADOWS @38 /* Do not make light of me. */
			SAY SPELL_DISRUPTED @39 /* Soo stupid! */

	END
END

COMPILE EVALUATE_BUFFER ~%MOD_FOLDER%/dlg/sod/JNMON9.d~
	~%MOD_FOLDER%/dlg/sod/JNBDMO.d~
	~%MOD_FOLDER%/dlg/sod/JNXZA9.d~
	~%MOD_FOLDER%/dlg/sod/JNBDXZ.d~
	
	~%MOD_FOLDER%/baf/sod/JNMON9S.baf~
	~%MOD_FOLDER%/baf/sod/JNXZA9S.baf~
	
// XP set script added to override script
EXTEND_BOTTOM ~JNMON9S.bcs~ ~%MOD_FOLDER%/baf/sod/general_script_additions.baf~
	EVALUATE_BUFFER

EXTEND_BOTTOM ~JNXZA9S.bcs~ ~%MOD_FOLDER%/baf/sod/general_script_additions.baf~
	EVALUATE_BUFFER

// Spawn script in the first camp area
EXTEND_TOP ~BD1000.bcs~ ~%MOD_FOLDER%/baf/sod/BD1000.baf~
	EVALUATE_BUFFER
	
// Move script in the second camp area
EXTEND_TOP ~BD7100.bcs~ ~%MOD_FOLDER%/baf/sod/BD7100.baf~
	EVALUATE_BUFFER
	
COPY_EXISTING ~BD7100.BCS~ ~override~
	DECOMPILE_AND_PATCH BEGIN
		SPRINT textToReplace ~\(SetGlobal("bd_move_npcs","bd7100",1)\)~
		COUNT_REGEXP_INSTANCES ~%textToReplace%~ num_matches
		PATCH_IF (num_matches > 0) BEGIN
			REPLACE_TEXTUALLY ~%textToReplace%~ ~\1 SetGlobal("JNMONT_MoveCamp","MYAREA",1) SetGlobal("JNXZAR_MoveCamp","MYAREA",1)~ 
			PATCH_PRINT ~Patching: %num_matches% matches found in %SOURCE_FILESPEC% for REPLACE_TEXTUALLY: %textToReplace%~
		END ELSE BEGIN
			PATCH_WARN ~WARNING: could not find %textToReplace% in %SOURCE_FILESPEC%~
		END
	END
BUT_ONLY

// Move script in the third camp area
EXTEND_TOP ~BD3000.bcs~ ~%MOD_FOLDER%/baf/sod/BD3000.baf~
	EVALUATE_BUFFER

COPY_EXISTING ~BD3000.BCS~ ~override~
	DECOMPILE_AND_PATCH BEGIN
		SPRINT textToReplace ~\(SetGlobal("bd_move_npcs","bd3000",1)\)~
		COUNT_REGEXP_INSTANCES ~%textToReplace%~ num_matches
		PATCH_IF (num_matches > 0) BEGIN
			REPLACE_TEXTUALLY ~%textToReplace%~ ~\1 SetGlobal("JNMONT_MoveCamp","MYAREA",1) SetGlobal("JNXZAR_MoveCamp","MYAREA",1)~ 
			PATCH_PRINT ~Patching: %num_matches% matches found in %SOURCE_FILESPEC% for REPLACE_TEXTUALLY: %textToReplace%~
		END ELSE BEGIN
			PATCH_WARN ~WARNING: could not find %textToReplace% in %SOURCE_FILESPEC%~
		END
	END
BUT_ONLY

// Crusade Battle Script
EXTEND_BOTTOM ~bdasc3.bcs~ ~%MOD_FOLDER%/baf/sod/BDASC3.baf~
	EVALUATE_BUFFER
	
COPY_EXISTING ~bd3000.BCS~ ~override~
	DECOMPILE_AND_PATCH BEGIN
		SPRINT textToReplace ~\(SetGlobal("bd_move_voghiln","bd3000",0)\)~
		COUNT_REGEXP_INSTANCES ~%textToReplace%~ num_matches
		PATCH_IF (num_matches > 0) BEGIN
			REPLACE_TEXTUALLY ~%textToReplace%~ ~\1 SetGlobal("JNMONT_MoveCamp","MYAREA",0) SetGlobal("JNXZAR_MoveCamp","MYAREA",0)~ 
			PATCH_PRINT ~Patching: %num_matches% matches found in %SOURCE_FILESPEC% for REPLACE_TEXTUALLY: %textToReplace%~
		END ELSE BEGIN
			PATCH_WARN ~WARNING: could not find %textToReplace% in %SOURCE_FILESPEC%~
		END
	END
BUT_ONLY

// script to return home when kicked out
EXTEND_TOP ~bdparty.bcs~ ~%MOD_FOLDER%/baf/sod/BDPARTY.baf~
  EVALUATE_BUFFER
  
// script to move Montaron & Xzar to the portal in hell, if they are left behind
EXTEND_TOP ~bdcut58.bcs~ ~%MOD_FOLDER%/baf/sod/BDCUT58.baf~
	EVALUATE_BUFFER

// script to move Montaron & Xzar into the Dragonspear Castle Basement at the end
EXTEND_TOP ~bdcut59b.bcs~ ~%MOD_FOLDER%/baf/sod/BDCUT59B.baf~
	EVALUATE_BUFFER
	
// script for displaying comments on skie's murder
EXTEND_TOP ~bd4100.bcs~ ~%MOD_FOLDER%/baf/sod/BD4100.baf~
	EVALUATE_BUFFER

// script to leave party after skie's murder
EXTEND_TOP ~bdcut61.bcs~ ~%MOD_FOLDER%/baf/sod/BDCUT61.baf~
	EVALUATE_BUFFER

BEGIN @2000 DESIGNATED 2000
REQUIRE_PREDICATE GAME_IS ~bg2ee eet~ @2001
FORBID_COMPONENT ~EET_end.tp2~ ~0~ @2002
FORBID_COMPONENT ~EET_end.tp2~ ~1~ @2002

ACTION_IF GAME_IS ~eet~ BEGIN
	OUTER_SPRINT jnmontdv ~Montaron~
END ELSE BEGIN
	OUTER_SPRINT jnmontdv ~JNMONT~
END

COPY ~%MOD_FOLDER%/tra/%LANGUAGE%/sound~ ~override~

COPY ~%MOD_FOLDER%/cre/JNMONT.cre~ ~override/JNMONT.cre~
	SAY NAME1 @2 /* Montaron */
	SAY NAME2 @2 /* Montaron */
	SAY INITIAL_MEETING @3 /* Keep yer distance, ye goody-goody. I no like the smell of charity. */
	SAY MORALE @4 /* A pox on ye! I'll no lose my neck to this lot! */
	SAY HAPPY @5 /* Effective. I may not kill you after all. */
	SAY UNHAPPY_ANNOYED @6 /* Ye goody goodies make me sick! */ 
	SAY UNHAPPY_SERIOUS @7 /* Any more of yer nice-nice and I'm gone! */
	SAY UNHAPPY_BREAKING @8 /* I'll suffer this group no more! Best ye sleep with one eye open! */
	SAY LEADER @9 /* I have no equal, but I prefer to work alone. */
	SAY TIRED @10 /* If'n I'm not allowed to sleep, our next assailants may just live. */
	SAY BORED @11 /* A good blade must be fed. Find prey or I find you. */
	SAY BATTLE_CRY1 @12 /* And the rivers run red! */
	SAY BATTLE_CRY2 @12 /* And the rivers run red! */
	SAY BATTLE_CRY3 @12 /* And the rivers run red! */
	SAY BATTLE_CRY4 @12 /* And the rivers run red! */
	SAY BATTLE_CRY5 @12 /* And the rivers run red! */
	SAY DAMAGE ~~ [JNmonda]
	SAY DYING ~~ [JNmondy]
	SAY HURT @15 /* A death be in me if I no get help. */
	SAY AREA_FOREST @16 /* I hate the woods. Prey be so much easier to find in the city. */
	SAY AREA_DUNGEON @18 /* Dungeons! The dark be nice, but blast this damp! */
	SAY AREA_DAY @19 /* I be much preferring the cover of night o'er this blasted daylight! */
	SAY SELECT_COMMON1 @21 /* Ye spoke at me? */
	SAY SELECT_COMMON2 @22 /* This better be good */
	SAY SELECT_COMMON3 @23 /* What need ye dead? */
	SAY SELECT_COMMON4 @21 /* Ye spoke at me? */
	SAY SELECT_COMMON5 @22 /* This better be good */
	SAY SELECT_COMMON6 @23 /* What need ye dead? */
	SAY SELECT_ACTION1 @24 /* I'll do yer toil. */
	SAY SELECT_ACTION2 @25 /* Go suck yer blade. */
	SAY SELECT_ACTION3 @26 /* Sleep lightly, taskmaster. */
	SAY SELECT_ACTION4 @27 /* I warrant your attention?! Oh frabjous day, callooh callay! */
	SAY SELECT_ACTION5 @28 /* Arrrr! */
	SAY SELECT_ACTION6 @29 /* Leave me be, lest your head leave yer neck. */
	SAY SELECT_ACTION7 @30 /* What part of "I'm a loner" do ye not understand?! */
	SAY SELECT_RARE1 @31 /* Good or bad, you'll go the way of all flesh. */
	SAY SELECT_RARE2 @32 /* 'Tis a wonder you've lived as long as ye have. */
	SAY CRITICAL_HIT @33 /* The smell of flesh! */
	SAY CRITICAL_MISS @34 /* some moan */
	SAY TARGET_IMMUNE @35 /* Yer wit be as sharp as my blade. */
	SAY PICKED_POCKET @36 /* My equal is a talent of many men. */
	SAY SET_A_TRAP @37 /* All of them fools! */
	SAY HIDDEN_IN_SHADOWS @38 /* Do not make light of me. */
	SAY SPELL_DISRUPTED @39 /* Soo stupid! */
	SAY BIO @40
	
	WRITE_ASCII 0x248 ~JNMONTS~ #8  // override script where you put all the commands for talks.
	WRITE_ASCII 0x2cc ~JNMONT~  #8  // dialogue file where we'll put Montaron's greeting dialogue.
	WRITE_ASCII 0x280 ~%jnmontdv%~  #32 // death variable - when we want to refer to Montaron in the game, we'll call him JNMONT. For example, InParty("JNMONT") means that Montaron is in party.
	WRITE_ASCII 0x34  ~MONTARM~ #8  // medium portrait
	WRITE_ASCII 0x3c  ~MONTARL~ #8  // large portrait
	
	// TOB

