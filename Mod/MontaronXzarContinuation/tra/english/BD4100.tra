@0 = ~Hah, ye finally put a stop to that annoyin' brat.~
@1 = ~Ye've it in ye after all. Well done <CHARNAME>, let the streets run red.~
@2 = ~Ahh... the sweet release of death delivered by <CHARNAME> <PRO_HIMHER>self.~
@3 = ~Murder an innocent girl? Oh, you have tricked us all.. or you were tricked.. tricked by me? No, I wouldn't...~