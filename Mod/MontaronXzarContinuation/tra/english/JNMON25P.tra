@0 = ~We be a mighty lot <CHARNAME>. Be ye sure ye don't want me blade at yer side?~
@1 = ~No, I made a mistake. Stay with me.~
@2 = ~Just wait for me here.~
@3 = ~I am sending you to the pocket plane. Wait for me there.~
@4 = ~Need ye my blade again?~
@5 = ~I do. Join me.~
@6 = ~Not at the moment.~
@7 = ~Point me at who ye need dead.~
@8 = ~Then why ye bother me!~